<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Image Sources — {{ projectName }}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: {{ bodyFont | default("system-ui, sans-serif") }}; background: {{ pageBg | default("#f5f0e8") }}; color: {{ textColor | default("#1a1a1a") }}; line-height: 1.6; }
    .page { max-width: 800px; margin: 0 auto; padding: 60px 24px; }
    h1 { font-family: {{ headingFont | default("Georgia, serif") }}; font-size: 2rem; margin-bottom: 8px; color: {{ primaryColor | default("#2c3e50") }}; }
    .subtitle { color: #888; margin-bottom: 48px; font-size: 0.95rem; }
    .museum { margin-bottom: 40px; }
    .museum-name { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: {{ accentColor | default("#8b6f47") }}; margin-bottom: 12px; border-bottom: 1px solid currentColor; padding-bottom: 4px; }
    .image-entry { padding: 14px 0; border-bottom: 1px solid rgba(0,0,0,0.08); }
    .image-entry:last-child { border-bottom: none; }
    .image-title { font-weight: 600; margin-bottom: 4px; }
    .image-meta { font-size: 0.85rem; color: #666; }
    .image-meta a { color: {{ accentColor | default("#8b6f47") }}; }
    .colophon { margin-top: 60px; padding-top: 24px; border-top: 1px solid rgba(0,0,0,0.12); font-size: 0.8rem; color: #aaa; }
    .back { display: inline-block; margin-bottom: 32px; color: {{ accentColor | default("#8b6f47") }}; text-decoration: none; font-size: 0.9rem; }
  </style>
</head>
<body>
  <div class="page">
    <a href="./index.html" class="back">← Back to site</a>
    <h1>Image Sources</h1>
    <p class="subtitle">All images used in this site are in the public domain. Full attribution is provided below.</p>

    {% for museum, images in imagesByMuseum %}
    <div class="museum">
      <p class="museum-name">{{ museum }}</p>
      {% for img in images %}
      <div class="image-entry">
        <p class="image-title">{{ img.title | default("Untitled") }}</p>
        <p class="image-meta">
          {% if img.artist %}{{ img.artist }}{% if img.date %}, {{ img.date }}{% endif %} &mdash; {% endif %}
          {% if img.source_url %}<a href="{{ img.source_url }}" target="_blank" rel="noopener">View at {{ museum }}</a> &mdash; {% endif %}
          Public domain
        </p>
      </div>
      {% endfor %}
    </div>
    {% endfor %}

    <div class="colophon">
      <p>This site was created with <strong>Fresco</strong> using the <strong>{{ templateName }}</strong> template.</p>
    </div>
  </div>
</body>
</html>
